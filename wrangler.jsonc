{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "restoraunch",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "restoraunch-db",
      // For local dev, run: npx wrangler d1 create restoraunch-db
      // Then replace this with the actual database_id from the output
      "database_id": "77c5134c-e098-45c5-ad62-b62e82a903c7"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_IMAGES",
      "bucket_name": "restoraunch-images"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
  // OPENROUTER_API_KEY should be set as a secret, not a var:
  // npx wrangler secret put OPENROUTER_API_KEY
}
