---
import { env } from 'cloudflare:workers';
import '../styles/global.css';
import Nav from '../components/Nav.vue';
import ScanButton from '../components/ScanButton.vue';
import Header from '../components/Header.vue';
import ProfilePanel from '../components/ProfilePanel.vue';
import { getUserById } from '../lib/db/users';

interface Props {
  title: string;
  hideNav?: boolean;
  hideScanButton?: boolean;
  hideHeader?: boolean;
}

const { title, hideNav = false, hideScanButton = false, hideHeader = false } = Astro.props;
const currentPath = Astro.url.pathname;

let userEmail = '';
let locationName = '';
let avatarUrl: string | undefined;

const authResult = Astro.locals.auth();
if (authResult.userId) {
  const { DB } = env;

  const user = await getUserById(DB, authResult.userId);
  if (user) {
    userEmail = user.email;
    avatarUrl = user.avatar_url || undefined;
  }

  const location = Astro.locals.location;
  if (location?.locationId) {
    const loc = await DB.prepare('SELECT name FROM locations WHERE id = ?')
      .bind(location.locationId)
      .first<{ name: string }>();
    locationName = loc?.name || '';
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="oklch(0.98 0.01 60)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} | Restoraunch</title>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>
  <body class="app-shell">
    {!hideHeader && userEmail && (
      <Header avatarUrl={avatarUrl} client:load />
    )}

    <div class="app-content">
      <slot />
    </div>

    {!hideScanButton && (
      <ScanButton client:load />
    )}

    {!hideNav && (
      <Nav currentPath={currentPath} client:load />
    )}

    {!hideHeader && userEmail && (
      <ProfilePanel
        userEmail={userEmail}
        locationName={locationName}
        client:load
      />
    )}

    <div id="modal-root"></div>

    <script>
      // Handle scan button click - navigate to inventory with scan param
      document.addEventListener('scan', () => {
        window.location.href = '/inventory?scan=true';
      });
    </script>

    <style is:global>
      .app-shell {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        padding-bottom: calc(4rem + env(safe-area-inset-bottom, 0px));
      }

      .app-content {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .app-shell:has(.header-container) .app-content {
        padding-top: calc(3.25rem + env(safe-area-inset-top, 0px));
      }

      /* Smooth scroll behavior */
      @media (prefers-reduced-motion: no-preference) {
        html {
          scroll-behavior: smooth;
        }
      }

      /* Custom focus styles */
      :focus-visible {
        outline: 2px solid oklch(0.55 0.12 60);
        outline-offset: 2px;
      }

      /* Selection color */
      ::selection {
        background: oklch(0.85 0.08 60);
        color: oklch(0.20 0.05 60);
      }
    </style>
  </body>
</html>
