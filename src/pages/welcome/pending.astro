---
import AppLayout from '../../layouts/AppLayout.astro'
import { SignOutButton } from '@clerk/astro/components'

const { userId } = Astro.locals.auth()

if (!userId) {
  return Astro.redirect('/sign-in')
}
---

<AppLayout title="Waiting for Invite" hideNav={true} hideScanButton={true}>
  <main class="pending-page">
    <div class="pending-content">
      <div class="icon-circle">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </div>

      <h1>Waiting for an Invitation</h1>

      <p>
        You're signed in, but you haven't been invited to any restaurants yet.
        Ask your manager to send you an invitation.
      </p>

      <div class="actions">
        <button onclick="location.reload()" class="btn-refresh">
          Check Again
        </button>
        <SignOutButton class="btn-signout">
          Sign Out
        </SignOutButton>
      </div>
    </div>
  </main>
</AppLayout>

<style>
  .pending-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: 2rem 1rem;
  }

  .pending-content {
    text-align: center;
    max-width: 400px;
  }

  .icon-circle {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(0.95 0.02 60);
    color: oklch(0.50 0.06 60);
    border-radius: 50%;
    margin: 0 auto 1.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: oklch(0.20 0.05 60);
    margin: 0 0 0.75rem;
  }

  p {
    font-size: 0.9375rem;
    color: oklch(0.50 0.06 60);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .btn-refresh {
    padding: 0.75rem 1.5rem;
    background: oklch(0.50 0.12 60);
    color: white;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 150ms ease;
  }

  .btn-refresh:hover {
    background: oklch(0.45 0.12 60);
  }

  :global(.btn-signout) {
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: oklch(0.50 0.06 60);
    border: 1px solid oklch(0.85 0.02 60);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 150ms ease;
  }

  :global(.btn-signout:hover) {
    border-color: oklch(0.70 0.04 60);
    color: oklch(0.35 0.06 60);
  }
</style>
