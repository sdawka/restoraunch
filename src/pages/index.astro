---
import AppLayout from '../layouts/AppLayout.astro';
import DashboardCards from '../components/DashboardCards.vue';
import TourPrompt from '../components/TourPrompt.vue';

const { userId } = Astro.locals.auth()

let isAuthenticated = false
if (userId) {
  isAuthenticated = true
  const { DB } = Astro.locals.runtime.env
  const locations = await DB.prepare(
    'SELECT location_id FROM user_locations WHERE user_id = ?'
  ).bind(userId).all()

  if (locations.results.length === 0) {
    return Astro.redirect('/onboarding')
  }
}
---

{!isAuthenticated ? (
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Restoraunch - Restaurant Inventory Management</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: linear-gradient(135deg, #fef7ed 0%, #fff7ed 100%);
        min-height: 100vh;
      }
      .landing {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
      }
      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
      }
      .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: #92400e;
      }
      .nav-links { display: flex; gap: 1rem; }
      .nav-links a {
        padding: 0.5rem 1rem;
        text-decoration: none;
        color: #78350f;
        font-weight: 500;
        border-radius: 8px;
        transition: background 0.2s;
      }
      .nav-links a:hover { background: rgba(146, 64, 14, 0.1); }
      .nav-links .cta {
        background: #92400e;
        color: white;
      }
      .nav-links .cta:hover { background: #78350f; }
      .hero {
        text-align: center;
        padding: 6rem 2rem;
      }
      .hero h1 {
        font-size: 3rem;
        color: #78350f;
        margin-bottom: 1.5rem;
        line-height: 1.2;
      }
      .hero p {
        font-size: 1.25rem;
        color: #92400e;
        max-width: 600px;
        margin: 0 auto 2rem;
      }
      .hero-cta {
        display: inline-block;
        background: #92400e;
        color: white;
        padding: 1rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.125rem;
        transition: background 0.2s;
      }
      .hero-cta:hover { background: #78350f; }
      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        padding: 4rem 0;
      }
      .feature {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      }
      .feature h3 {
        color: #78350f;
        margin-bottom: 0.5rem;
      }
      .feature p { color: #a16207; }
    </style>
  </head>
  <body>
    <div class="landing">
      <nav class="nav">
        <div class="logo">Restoraunch</div>
        <div class="nav-links">
          <a href="/sign-in">Sign In</a>
          <a href="/sign-up" class="cta">Get Started</a>
        </div>
      </nav>
      <section class="hero">
        <h1>Restaurant Inventory,<br/>Simplified</h1>
        <p>Track ingredients, monitor costs, reduce waste. Built for restaurants that want to run smarter.</p>
        <a href="/sign-up" class="hero-cta">Start Free</a>
      </section>
      <section class="features">
        <div class="feature">
          <h3>Inventory Tracking</h3>
          <p>Scan barcodes, count stock, and know exactly what you have on hand.</p>
        </div>
        <div class="feature">
          <h3>Cost Analysis</h3>
          <p>See your actual food costs and identify where money is going.</p>
        </div>
        <div class="feature">
          <h3>Team Access</h3>
          <p>Invite managers to help track inventory across locations.</p>
        </div>
      </section>
    </div>
  </body>
</html>
) : (
<AppLayout title="Dashboard">
  <main class="dashboard-page">
    <header class="page-header">
      <div class="header-content">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Today's overview</p>
      </div>
      <time class="current-date" datetime={new Date().toISOString().split('T')[0]}>
        {new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' })}
      </time>
    </header>

    <TourPrompt client:load />
    <DashboardCards client:load />
  </main>
</AppLayout>

<style>
  .dashboard-page {
    padding: 1rem;
    min-height: 100dvh;
  }

  @media (min-width: 768px) {
    .dashboard-page {
      padding: 1.5rem 2rem;
    }
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid oklch(0.90 0.03 60);
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: oklch(0.25 0.05 60);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: 1.75rem;
    }
  }

  .page-subtitle {
    font-size: 0.875rem;
    color: oklch(0.55 0.10 60);
  }

  .current-date {
    font-size: 0.875rem;
    font-weight: 500;
    color: oklch(0.55 0.10 60);
    background: oklch(0.95 0.02 60);
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
  }
</style>
)}
