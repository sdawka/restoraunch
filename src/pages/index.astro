---
import AppLayout from '../layouts/AppLayout.astro';
import DashboardCards from '../components/DashboardCards.vue';
import TourPrompt from '../components/TourPrompt.vue';
---

<AppLayout title="Dashboard">
  <main class="dashboard-page">
    <header class="page-header">
      <div class="header-content">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Today's overview</p>
      </div>
      <time class="current-date" datetime={new Date().toISOString().split('T')[0]}>
        {new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' })}
      </time>
    </header>

    <TourPrompt client:load />
    <DashboardCards client:load />
  </main>
</AppLayout>

<style>
  .dashboard-page {
    padding: 1rem;
    min-height: 100dvh;
  }

  @media (min-width: 768px) {
    .dashboard-page {
      padding: 1.5rem 2rem;
    }
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid oklch(0.90 0.03 60);
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: oklch(0.25 0.05 60);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: 1.75rem;
    }
  }

  .page-subtitle {
    font-size: 0.875rem;
    color: oklch(0.55 0.10 60);
  }

  .current-date {
    font-size: 0.875rem;
    font-weight: 500;
    color: oklch(0.55 0.10 60);
    background: oklch(0.95 0.02 60);
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
  }
</style>
