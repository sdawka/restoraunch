---
import AppLayout from '../layouts/AppLayout.astro';
import Nav from '../components/Nav.vue';
import SalesImport from '../components/SalesImport.vue';
---

<AppLayout title="Sales">
  <div class="sales-page">
    <!-- Header with title and import -->
    <header class="sales-header">
      <div class="header-content">
        <div class="header-title">
          <h1>Sales</h1>
          <p class="subtitle">Revenue & profit tracking</p>
        </div>
      </div>
    </header>

    <!-- Date Range Selector -->
    <div class="date-range-bar">
      <div class="date-range-inner">
        <button class="range-btn range-btn--active" data-range="today">Today</button>
        <button class="range-btn" data-range="7d">Last 7 days</button>
        <button class="range-btn" data-range="custom">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="calendar-icon">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          Custom
        </button>
      </div>

      <!-- Custom Date Picker (hidden by default) -->
      <div class="custom-dates" id="customDates" style="display: none;">
        <input type="date" id="startDate" class="date-input" />
        <span class="date-separator">to</span>
        <input type="date" id="endDate" class="date-input" />
        <button class="apply-btn" id="applyDates">Apply</button>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="summary-cards">
      <div class="summary-card summary-card--revenue">
        <span class="card-label">Revenue</span>
        <span class="card-value" id="totalRevenue">$0.00</span>
      </div>
      <div class="summary-card summary-card--cost">
        <span class="card-label">Cost</span>
        <span class="card-value" id="totalCost">$0.00</span>
      </div>
      <div class="summary-card summary-card--profit">
        <span class="card-label">Profit</span>
        <span class="card-value" id="totalProfit">$0.00</span>
        <span class="card-pct" id="profitMargin">0%</span>
      </div>
    </div>

    <!-- Daily Summary -->
    <section class="daily-section">
      <h2 class="section-title">Daily Summary</h2>
      <div class="daily-list" id="dailyList">
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 3v18h18" />
            <path d="M18 9l-5 5-4-4-3 3" />
          </svg>
          <p>No sales data for this period</p>
        </div>
      </div>
    </section>

    <!-- Item Breakdown -->
    <section class="items-section">
      <h2 class="section-title">By Menu Item</h2>
      <div class="items-list" id="itemsList">
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
            <rect x="9" y="3" width="6" height="4" rx="1" />
          </svg>
          <p>No items sold yet</p>
        </div>
      </div>
    </section>

    <!-- Import Component -->
    <SalesImport client:load />

    <!-- Bottom spacer for nav -->
    <div class="nav-spacer"></div>
  </div>

  <Nav currentPath="/sales" client:load />
</AppLayout>

<style>
  .sales-page {
    min-height: 100dvh;
    background: linear-gradient(180deg, oklch(0.985 0.008 60) 0%, oklch(0.96 0.015 60) 100%);
    padding-bottom: 5rem;
  }

  .sales-header {
    background: oklch(0.995 0.003 60);
    border-bottom: 1px solid oklch(0.92 0.02 60);
    padding: 1.25rem 1rem 1rem;
  }

  .header-content {
    max-width: 32rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .header-title h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 2rem;
    font-weight: 400;
    color: oklch(0.22 0.04 60);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .subtitle {
    font-size: 0.8125rem;
    color: oklch(0.55 0.04 60);
    margin-top: 0.25rem;
    font-weight: 450;
  }

  /* Date Range Selector */
  .date-range-bar {
    background: oklch(0.995 0.003 60);
    border-bottom: 1px solid oklch(0.92 0.02 60);
    padding: 0.75rem 1rem;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .date-range-inner {
    max-width: 32rem;
    margin: 0 auto;
    display: flex;
    gap: 0.5rem;
  }

  .range-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.625rem 0.75rem;
    background: oklch(0.97 0.01 60);
    border: 1px solid oklch(0.90 0.025 60);
    border-radius: 0.625rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: oklch(0.45 0.06 60);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .range-btn:hover {
    background: oklch(0.94 0.02 60);
    border-color: oklch(0.85 0.04 60);
  }

  .range-btn--active {
    background: oklch(0.35 0.08 60);
    border-color: oklch(0.35 0.08 60);
    color: oklch(0.98 0.01 60);
  }

  .range-btn--active:hover {
    background: oklch(0.30 0.08 60);
    border-color: oklch(0.30 0.08 60);
  }

  .calendar-icon {
    width: 1rem;
    height: 1rem;
  }

  .custom-dates {
    max-width: 32rem;
    margin: 0.75rem auto 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .date-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid oklch(0.88 0.025 60);
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    background: oklch(0.995 0.003 60);
    color: oklch(0.25 0.04 60);
  }

  .date-separator {
    font-size: 0.75rem;
    color: oklch(0.55 0.04 60);
    font-weight: 500;
  }

  .apply-btn {
    padding: 0.5rem 1rem;
    background: oklch(0.35 0.08 60);
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }

  .apply-btn:hover {
    background: oklch(0.30 0.08 60);
  }

  /* Summary Cards */
  .summary-cards {
    max-width: 32rem;
    margin: 1rem auto 0;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .summary-card {
    background: oklch(0.995 0.003 60);
    border: 1px solid oklch(0.92 0.02 60);
    border-radius: 0.875rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .summary-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .summary-card--revenue::before {
    background: oklch(0.65 0.12 230);
  }

  .summary-card--cost::before {
    background: oklch(0.70 0.14 40);
  }

  .summary-card--profit::before {
    background: oklch(0.60 0.17 145);
  }

  .card-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: oklch(0.55 0.04 60);
    font-weight: 600;
  }

  .card-value {
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 1.25rem;
    font-weight: 500;
    color: oklch(0.22 0.04 60);
    margin-top: 0.375rem;
    letter-spacing: -0.02em;
  }

  .card-pct {
    font-size: 0.75rem;
    font-weight: 600;
    color: oklch(0.50 0.12 145);
    margin-top: 0.25rem;
  }

  /* Sections */
  .daily-section,
  .items-section {
    max-width: 32rem;
    margin: 1.5rem auto 0;
    padding: 0 1rem;
  }

  .section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: oklch(0.50 0.05 60);
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }

  .daily-list,
  .items-list {
    background: oklch(0.995 0.003 60);
    border: 1px solid oklch(0.92 0.02 60);
    border-radius: 0.875rem;
    overflow: hidden;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem;
    color: oklch(0.60 0.04 60);
    gap: 0.75rem;
  }

  .empty-state svg {
    width: 2.5rem;
    height: 2.5rem;
    opacity: 0.5;
  }

  .empty-state p {
    font-size: 0.875rem;
    font-weight: 450;
  }

  .nav-spacer {
    height: 1rem;
  }

  /* Day row styles - used by JS */
  :global(.day-row) {
    display: flex;
    align-items: center;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid oklch(0.94 0.015 60);
  }

  :global(.day-row:last-child) {
    border-bottom: none;
  }

  :global(.day-date) {
    flex: 1;
    font-weight: 500;
    font-size: 0.875rem;
    color: oklch(0.30 0.04 60);
  }

  :global(.day-meta) {
    font-size: 0.75rem;
    color: oklch(0.55 0.04 60);
    font-weight: 450;
  }

  :global(.day-numbers) {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  :global(.day-revenue) {
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: oklch(0.30 0.04 60);
  }

  :global(.day-profit) {
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 0.8125rem;
    color: oklch(0.50 0.12 145);
    font-weight: 500;
  }

  /* Item row styles - used by JS */
  :global(.item-row) {
    display: flex;
    align-items: center;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid oklch(0.94 0.015 60);
    gap: 0.75rem;
  }

  :global(.item-row:last-child) {
    border-bottom: none;
  }

  :global(.item-qty) {
    width: 2.5rem;
    height: 2.5rem;
    background: oklch(0.95 0.015 60);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 600;
    color: oklch(0.40 0.06 60);
  }

  :global(.item-info) {
    flex: 1;
    min-width: 0;
  }

  :global(.item-name) {
    font-weight: 500;
    font-size: 0.875rem;
    color: oklch(0.25 0.04 60);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.item-price) {
    font-size: 0.75rem;
    color: oklch(0.55 0.04 60);
    margin-top: 0.125rem;
  }

  :global(.item-totals) {
    text-align: right;
  }

  :global(.item-revenue) {
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: oklch(0.30 0.04 60);
  }

  :global(.item-profit) {
    font-family: 'DM Mono', 'SF Mono', monospace;
    font-size: 0.75rem;
    color: oklch(0.50 0.12 145);
    font-weight: 500;
    margin-top: 0.125rem;
  }

  :global(.item-profit--negative) {
    color: oklch(0.55 0.15 25);
  }

  /* Loading state */
  :global(.loading-shimmer) {
    background: linear-gradient(
      90deg,
      oklch(0.94 0.01 60) 0%,
      oklch(0.97 0.01 60) 50%,
      oklch(0.94 0.01 60) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 0.25rem;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  // Date range logic
  const rangeBtns = document.querySelectorAll('.range-btn');
  const customDates = document.getElementById('customDates');
  const startDateInput = document.getElementById('startDate') as HTMLInputElement;
  const endDateInput = document.getElementById('endDate') as HTMLInputElement;
  const applyBtn = document.getElementById('applyDates');

  function formatDate(date: Date): string {
    return date.toISOString().split('T')[0];
  }

  function formatDisplayDate(dateStr: string): string {
    const date = new Date(dateStr + 'T12:00:00');
    const today = new Date();
    const yesterday = new Date(today);
    yesterday.setDate(yesterday.getDate() - 1);

    if (dateStr === formatDate(today)) return 'Today';
    if (dateStr === formatDate(yesterday)) return 'Yesterday';

    return date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
  }

  function getDateRange(range: string): { start: string; end: string } {
    const today = new Date();
    const end = formatDate(today);

    switch (range) {
      case 'today':
        return { start: end, end };
      case '7d': {
        const start = new Date(today);
        start.setDate(start.getDate() - 6);
        return { start: formatDate(start), end };
      }
      case 'custom':
        return {
          start: startDateInput?.value || end,
          end: endDateInput?.value || end
        };
      default:
        return { start: end, end };
    }
  }

  function formatCurrency(amount: number): string {
    return '$' + amount.toFixed(2);
  }

  function renderDayRow(day: { date: string; itemCount: number; totalRevenue: number; totalProfit: number }): HTMLElement {
    const row = document.createElement('div');
    row.className = 'day-row';

    const infoDiv = document.createElement('div');
    infoDiv.style.flex = '1';

    const dateDiv = document.createElement('div');
    dateDiv.className = 'day-date';
    dateDiv.textContent = formatDisplayDate(day.date);
    infoDiv.appendChild(dateDiv);

    const metaDiv = document.createElement('div');
    metaDiv.className = 'day-meta';
    metaDiv.textContent = `${day.itemCount} items sold`;
    infoDiv.appendChild(metaDiv);

    row.appendChild(infoDiv);

    const numbersDiv = document.createElement('div');
    numbersDiv.className = 'day-numbers';

    const revenueSpan = document.createElement('span');
    revenueSpan.className = 'day-revenue';
    revenueSpan.textContent = formatCurrency(day.totalRevenue);
    numbersDiv.appendChild(revenueSpan);

    const profitSpan = document.createElement('span');
    profitSpan.className = 'day-profit';
    profitSpan.textContent = '+' + formatCurrency(day.totalProfit);
    numbersDiv.appendChild(profitSpan);

    row.appendChild(numbersDiv);
    return row;
  }

  function renderItemRow(item: { menuItemName: string; quantity: number; unitPrice: number; totalRevenue: number; totalProfit: number }): HTMLElement {
    const row = document.createElement('div');
    row.className = 'item-row';

    const qtyDiv = document.createElement('div');
    qtyDiv.className = 'item-qty';
    qtyDiv.textContent = String(item.quantity);
    row.appendChild(qtyDiv);

    const infoDiv = document.createElement('div');
    infoDiv.className = 'item-info';

    const nameDiv = document.createElement('div');
    nameDiv.className = 'item-name';
    nameDiv.textContent = item.menuItemName;
    infoDiv.appendChild(nameDiv);

    const priceDiv = document.createElement('div');
    priceDiv.className = 'item-price';
    priceDiv.textContent = formatCurrency(item.unitPrice) + ' each';
    infoDiv.appendChild(priceDiv);

    row.appendChild(infoDiv);

    const totalsDiv = document.createElement('div');
    totalsDiv.className = 'item-totals';

    const revenueDiv = document.createElement('div');
    revenueDiv.className = 'item-revenue';
    revenueDiv.textContent = formatCurrency(item.totalRevenue);
    totalsDiv.appendChild(revenueDiv);

    const profitDiv = document.createElement('div');
    profitDiv.className = 'item-profit' + (item.totalProfit < 0 ? ' item-profit--negative' : '');
    profitDiv.textContent = (item.totalProfit >= 0 ? '+' : '') + formatCurrency(item.totalProfit);
    totalsDiv.appendChild(profitDiv);

    row.appendChild(totalsDiv);
    return row;
  }

  function renderEmptyState(message: string, iconType: 'chart' | 'clipboard'): HTMLElement {
    const container = document.createElement('div');
    container.className = 'empty-state';

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '1.5');

    if (iconType === 'chart') {
      const path1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path1.setAttribute('d', 'M3 3v18h18');
      svg.appendChild(path1);
      const path2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path2.setAttribute('d', 'M18 9l-5 5-4-4-3 3');
      svg.appendChild(path2);
    } else {
      const path1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path1.setAttribute('d', 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2');
      svg.appendChild(path1);
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', '9');
      rect.setAttribute('y', '3');
      rect.setAttribute('width', '6');
      rect.setAttribute('height', '4');
      rect.setAttribute('rx', '1');
      svg.appendChild(rect);
    }

    container.appendChild(svg);

    const p = document.createElement('p');
    p.textContent = message;
    container.appendChild(p);

    return container;
  }

  async function loadSalesData(range: string) {
    const { start, end } = getDateRange(range);

    // Show loading state
    const dailyList = document.getElementById('dailyList');
    const itemsList = document.getElementById('itemsList');

    if (dailyList) {
      dailyList.textContent = '';
      const shimmer = document.createElement('div');
      shimmer.className = 'loading-shimmer';
      shimmer.style.height = '3rem';
      shimmer.style.margin = '1rem';
      dailyList.appendChild(shimmer);
    }
    if (itemsList) {
      itemsList.textContent = '';
      const shimmer = document.createElement('div');
      shimmer.className = 'loading-shimmer';
      shimmer.style.height = '3rem';
      shimmer.style.margin = '1rem';
      itemsList.appendChild(shimmer);
    }

    try {
      // Fetch daily summary
      const dailyRes = await fetch(`/api/sales/daily?start=${start}&end=${end}`);
      const dailyData = await dailyRes.json();

      // Fetch items breakdown
      const itemsRes = await fetch(`/api/sales/items?start=${start}&end=${end}`);
      const itemsData = await itemsRes.json();

      // Update totals
      let totalRevenue = 0;
      let totalCost = 0;
      let totalProfit = 0;

      if (itemsData.items && itemsData.items.length > 0) {
        for (const item of itemsData.items) {
          totalRevenue += item.totalRevenue;
          totalCost += item.totalCost;
          totalProfit += item.totalProfit;
        }
      }

      const revenueEl = document.getElementById('totalRevenue');
      const costEl = document.getElementById('totalCost');
      const profitEl = document.getElementById('totalProfit');
      const marginEl = document.getElementById('profitMargin');

      if (revenueEl) revenueEl.textContent = formatCurrency(totalRevenue);
      if (costEl) costEl.textContent = formatCurrency(totalCost);
      if (profitEl) profitEl.textContent = formatCurrency(totalProfit);
      if (marginEl) {
        const margin = totalRevenue > 0 ? (totalProfit / totalRevenue * 100).toFixed(1) : '0';
        marginEl.textContent = margin + '% margin';
      }

      // Render daily summary
      if (dailyList) {
        dailyList.textContent = '';
        if (dailyData.daily && dailyData.daily.length > 0) {
          for (const day of dailyData.daily) {
            dailyList.appendChild(renderDayRow(day));
          }
        } else {
          dailyList.appendChild(renderEmptyState('No sales data for this period', 'chart'));
        }
      }

      // Render items breakdown
      if (itemsList) {
        itemsList.textContent = '';
        if (itemsData.items && itemsData.items.length > 0) {
          for (const item of itemsData.items) {
            itemsList.appendChild(renderItemRow(item));
          }
        } else {
          itemsList.appendChild(renderEmptyState('No items sold yet', 'clipboard'));
        }
      }
    } catch (error) {
      console.error('Failed to load sales data:', error);
    }
  }

  // Set up event listeners
  rangeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const range = (btn as HTMLElement).dataset.range;
      if (!range) return;

      rangeBtns.forEach(b => b.classList.remove('range-btn--active'));
      btn.classList.add('range-btn--active');

      if (range === 'custom' && customDates) {
        customDates.style.display = 'flex';
        // Set default dates
        const today = new Date();
        const weekAgo = new Date(today);
        weekAgo.setDate(weekAgo.getDate() - 7);
        if (startDateInput) startDateInput.value = formatDate(weekAgo);
        if (endDateInput) endDateInput.value = formatDate(today);
      } else {
        if (customDates) customDates.style.display = 'none';
        loadSalesData(range);
      }
    });
  });

  applyBtn?.addEventListener('click', () => {
    loadSalesData('custom');
  });

  // Initial load
  loadSalesData('today');
</script>
