---
import AppLayout from '../layouts/AppLayout.astro';
import ScenarioBuilder from '../components/ScenarioBuilder.vue';

export const prerender = false;
---

<AppLayout title="What-If Modeling">
  <main class="model-page">
    <a href="/insights" class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      <span>Back to Insights</span>
    </a>

    <ScenarioBuilder client:only="vue" />
  </main>
</AppLayout>

<style>
  .model-page {
    min-height: 100dvh;
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin: 1rem 1rem 0;
    padding: 0.375rem 0.625rem 0.375rem 0.25rem;

    background: transparent;
    border: none;
    border-radius: 0.375rem;

    font-size: 0.8125rem;
    font-weight: 500;
    color: oklch(0.50 0.08 60);
    text-decoration: none;

    transition: all 0.2s ease;
  }

  .back-link:hover {
    color: oklch(0.40 0.10 60);
    background: oklch(0.95 0.02 60);
  }

  .back-link svg {
    width: 1.125rem;
    height: 1.125rem;
  }
</style>
